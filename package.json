{
  "name": "githappens_v1",
  "version": "1.0.0",
  "private": true,
  "workspaces": [
    "client",
    "server"
  ],
  "scripts": {
    "dev": "npm-run-all --parallel dev:client dev:server",
    "dev:test": "npm-run-all --parallel dev:test-server dev:client",
    "dev:client": "npm --prefix client run dev",
    "dev:server": "npm --prefix server run dev",
    "dev:test-server": "npm --prefix server run dev:test",
    "start": "node server/server.js",
    "build": "npm --prefix client install && npm --prefix client run build",
    "test": "npm-run-all test:client test:server",
    "test:client": "npm --prefix client test",
    "test:server": "npm --prefix server test",
    "e2e": "cypress open",
    "e2e:run": "cypress run",
    "format": "prettier . --write",
    "format:check": "prettier . --check"
  },
  "devDependencies": {
    "cross-env": "^10.1.0",
    "cypress": "^15.14.2",
    "npm-run-all": "^4.1.5",
    "prettier": "^3.8.3"
  },
  "author": "Samit Sandhu",
  "license": "ISC",
  "dependencies": {
    "resend": "^6.12.3"
  }
}
